CF_ACCOUNT_ID=your_cloudflare_account_id
CF_API_TOKEN=your_cloudflare_api_token
OPEN_ROUTER_API_KEY=your_openrouter_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key   # optional
OPENAI_API_KEY=your_openai_api_key         # optional

MAX_WORKERS=5

PROVIDER=openrouter
TARGET_PROVIDER=openrouter
TARGET_MODEL=deepseek/deepseek-v3.2
JUDGE_MODEL=deepseek/deepseek-v4-flash
BUILDER_MODEL=deepseek/deepseek-v3.2
LLAMA_GUARD_MODEL=meta-llama/llama-guard-3-8b

# Optional: run target locally via LM Studio
# TARGET_PROVIDER=lmstudio
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
# TARGET_MODEL=your-local-model
